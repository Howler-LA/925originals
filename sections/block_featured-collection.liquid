<div class="pt-10 pb-2.5 flex flex-col justify-center items-center">
  <h2 class="sr-only">
    {{ section.settings.title | escape }}
  </h2>
  <div class="w-full px-6 lg:px-20 flex w-full snap-x overflow-x-auto lg:grid lg:grid-cols-3 gap-5 lg:gap-20">
    {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
      {%- 
        render 'card-product-single', 
        card_product: product, 
        wrapper_class: 'w-80' 
      -%}
    {%- else -%}
      {%- for i in (1..3) -%}
        {% render 'card-product-single' %}
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Maximum products to show",
      "default": 5,
      "min": 5,
      "max": 15,
      "step": 1
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}

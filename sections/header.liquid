{% schema %}
  {
    "name": "header",
    "class": "section-header sticky top-0 z-20",
    "tag": "header",
    "settings": [
      {
      "type": "paragraph",
      "content": "t:sections.header.settings.paragraph"
      }
    ]
  }
{% endschema %}

{% if settings.show_promo_bar %}
  {% render 'promo-bar' %}
{% endif %}

<div class="p-4 lg:px-20 lg:pt-20">
  <div class="flex items-center gap-8 relative">
    <nav
      :class="$store.global.isMobileMenuVisible ? 'open' : 'closed'"
      aria-label="Mobile Navigation Overlay"
      class="block md:hidden"
      style="transition: all 300ms;"
      id="mobile-nav"
      role="navigation"
      x-cloak 
      x-data>
      <button
        id="mobile-nav-trigger"
        type="button"
        @click="$store.global.toggleMobileMenu()"
        :aria-expanded="$store.global.isMobileMenuVisible"
        aria-label="Mobile Navigation Button"
        aria-controls="mobile-menu-list"
        x-data>
        <span class="sr-only">Menu</span>
        <span aria-hidden="true" x-show="!$store.global.isMobileMenuVisible">
          {% render 'icon-hamburger' %}
        </span>
        <span aria-hidden="true" x-show="$store.global.isMobileMenuVisible">
          {% render 'icon-close-x' %}
        </span>
      </button>
      {% render 'mobile-menu' %}
    </nav>

    <div class="hidden md:block">
      {% render 'header-menu' %}
    </div>

    <div class="flex items-center gap-8 self-center ml-auto">

      <a href="{{ routes.root_url }}" class="header-logo font-medium">
        925Originals
      </a>

      <div class="flex items-center gap-2">
        <button type="button" x-data @click="$store.global.isMinicartVisible = true">
          Your Cart
        </button>
        <a
          href="{{ routes.cart_url }}"
          class="border border-neutral-600 rounded-md size-5 flex items-center justify-center text-sm font-medium"
          x-cloak
        >
          <span data-ajax-cart-bind="item_count">
            {{- cart.item_count -}}
          </span>
        </a>
      </div>
      
    </div>

  </div>

  <style>

    #mobile-nav-trigger {
      display: none;
      -webkit-appearance: none;
      appearance: none;
      -moz-appearance: none;
      background: transparent;
      border: 0;
    }

    #mobile-nav-trigger svg {
      fill: white;
      width: 26px;
      height: auto;
    }

    @media(max-width: 768px) {
      .section-header .header-logo {
        /* position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%); */
        font-size: 1.5rem;
        margin-left: 1rem;
      }

      #mobile-nav-trigger {
        display: block;
      }
    }

    .cart-icon-wrapper {
      text-decoration: none;
      color: white;
      margin-left: auto;
      position: relative;
    }

    .cart-icon-wrapper span {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -35%);
      z-index: 5;
      font-size: 12px;
      font-weight: bold;
    }

    .bi-bag {
      display: none;
    }

    .js-ajax-cart-not-empty .header .bi-bag-fill {
      display: block;
    }

    .js-ajax-cart-empty .header .bi-bag-empty {
      display: block;
    }

    .js-ajax-cart-empty .header .bi-bag-fill {
      display: none;
    }
  </style>
</div>

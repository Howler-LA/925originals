{% schema %}
  {
    "name": "footer",
    "class": "footer",
    "tag": "footer",
    "settings": [
      {
        "type": "paragraph",
        "content": "t:sections.footer.settings.paragraph"
      }
    ]
  }
{% endschema %}

<footer class="p-4 lg:p-20 border-t text-sm">
  <div class="flex flex-col gap-4 lg:gap-10">
    <div class="grid lg:grid-cols-4 lg:gap-20">

      <div class="flex flex-col gap-2 text-neutral-500">
        <a href="#" class="text-sm">Free shipping on orders over $400</a>
        <a href="#" class="text-sm">Credit card, Apple Pay, Paypal, Klarna</a>
        <a href="#" class="text-sm">Free returns within 14 days.</a>
      </div>

      <div class="columns-2 space-y-2">
        {% for link in linklists.footer.links %}
          <a href="{{ link.url }}" class="block">{{ link.title }}</a>
        {% endfor %}
      </div>

      <div class="h-full bg-neutral-50"></div>
      <div class="h-full bg-neutral-50"></div>

    </div>
    <div class="">
      © {{ "now" | date: "%Y" }} 925Originals
    </div>
  </div>
</footer>

{% schema %}
  {
    "name": "footer",
    "class": "footer",
    "tag": "footer",
    "settings": [
      {
        "type": "paragraph",
        "content": "t:sections.footer.settings.paragraph"
      }
    ]
  }
{% endschema %}

<footer class="p-4 lg:p-20 border-t">
  <div class="flex flex-col gap-4 lg:gap-10">
    <div class="h-20 bg-neutral-50"></div>
    <div class="h-20 bg-neutral-50"></div>
  </div>
</footer>

{% comment %} <div class="px-6 md:px-8 py-12">
  <div class="container">
    <div>
      {% for link in linklists.footer.links %}
        <a href="{{ link.url }}">
          {{ link.title }}
        </a>
      {% endfor %}
    </div>
  
    <small>
      &copy; {{ "now" | date: "%Y" }} Slayed Starter Theme
    </small>
  </div>
</div> {% endcomment %}

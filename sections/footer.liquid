{% schema %}
  {
    "name": "footer",
    "class": "footer",
    "tag": "footer",
    "settings": [
      {
        "type": "paragraph",
        "content": "t:sections.footer.settings.paragraph"
      }
    ]
  }
{% endschema %}

<footer class="p-4 lg:p-20 border-t">
  <div class="flex flex-col gap-4 lg:gap-10">
    <div class="grid lg:grid-cols-4 lg:gap-20">

      <div class="flex flex-col gap-2">
        <a href="#" class="text-sm">Our Story</a>
        <a href="#" class="text-sm">Careers</a>
        <a href="#" class="text-sm">Press</a>
      </div>

      <div class="flex flex-col gap-2">
        <a href="#" class="text-sm">Contact Us</a>
        <a href="#" class="text-sm">Shipping</a>
        <a href="#" class="text-sm">Returns</a>
      </div>

      <div class="flex flex-col gap-2">
        <a href="#" class="text-sm">Log In</a>
        <a href="#" class="text-sm">Order Status</a>
        <a href="#" class="text-sm">View Cart</a>
      </div>

      <div class="flex flex-col gap-2">
        <a href="#" class="text-sm">Privacy Policy</a>
        <a href="#" class="text-sm">Terms of Use</a>
      </div>

    </div>
    <div class="h-20 bg-neutral-50"></div>
  </div>
</footer>

{% comment %} <div class="px-6 md:px-8 py-12">
  <div class="container">
    <div>
      {% for link in linklists.footer.links %}
        <a href="{{ link.url }}">
          {{ link.title }}
        </a>
      {% endfor %}
    </div>
  
    <small>
      &copy; {{ "now" | date: "%Y" }} Slayed Starter Theme
    </small>
  </div>
</div> {% endcomment %}
